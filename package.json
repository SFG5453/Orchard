{
  "name": "orchard",
  "version": "3.0.0",
  "description": "A Quasar, Vue, Socket.IO, Electron YouTube Music client backed by InnerTube.",
  "homepage": "https://github.com/sfg5453/orchard",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/sfg5453/orchard.git"
  },
  "desktopName": "dev.sfg.orchard",
  "main": "electron/main/index.js",
  "type": "module",
  "private": true,
  "scripts": {
    "dev": "npm run build:native && concurrently -k \"vite --host 127.0.0.1 --port 5173\" \"wait-on http://127.0.0.1:5173 && node scripts/launch-electron.mjs --dev-server=http://127.0.0.1:5173\"",
    "build": "npm run build:native && npm run build:frontend",
    "build:native": "node-gyp rebuild --directory native",
    "build:native:macos:cross": "sh scripts/build-native-macos-cross.sh",
    "build:native:windows": "sh scripts/build-native-windows.sh",
    "build:frontend": "vite build",
    "start": "npm run build && node scripts/launch-electron.mjs",
    "build:artist-pack": "node scripts/build-official-artist-pack.mjs",
    "package": "npm run build && electron-builder --config electron-builder.config.cjs --dir",
    "package:linux-system": "npm run build && node scripts/package-system-electron.mjs",
    "make": "npm run build && electron-builder --config electron-builder.config.cjs",
    "make:mac": "sh scripts/build-macos-cross.sh",
    "dist": "npm run make",
    "test": "node --test test/*.test.js",
    "test:native": "node --test test/nativeAudioAnalysis.test.js test/audioAnalysisService.test.js test/smartCrossfadeAnalysis.test.js test/queueTransitionSort.test.js test/transitionPlanner.test.js test/crossfadeMixer.test.js test/autoCrossfade.test.js test/subscribedArtists.test.js test/libraryCategory.test.js"
  },
  "keywords": [
    "quasar",
    "vue",
    "electron",
    "innertube",
    "ytmusic"
  ],
  "author": {
    "name": "SFG545",
    "email": "sfg@sfg545.dev"
  },
  "license": "MIT",
  "dependencies": {
    "@quasar/extras": "^2.0.2",
    "@quasar/vite-plugin": "^1.12.0",
    "@tonaljs/note": "^4.12.1",
    "@vitejs/plugin-vue": "^6.0.8",
    "@xhayper/discord-rpc": "^1.3.4",
    "@xmldom/xmldom": "^0.9.10",
    "concurrently": "^10.0.3",
    "electron-updater": "^6.8.9",
    "fflate": "^0.8.3",
    "gsap": "^3.15.0",
    "hls.js": "^1.6.16",
    "idb-keyval": "^6.3.0",
    "lastfm": "^0.9.4",
    "lrclib-api": "^2.0.4",
    "meyda": "^5.6.3",
    "ml-kmeans": "^7.0.1",
    "music-tempo": "^1.0.3",
    "node-addon-api": "^8.9.0",
    "node-vibrant": "^4.0.4",
    "pixi.js": "^8.19.0",
    "qrcode": "^1.5.4",
    "quasar": "^2.21.4",
    "socket.io": "^4.8.3",
    "socket.io-client": "^4.8.3",
    "standardized-audio-context": "^25.3.77",
    "vite": "^8.1.5",
    "vue": "^3.5.40",
    "wait-on": "^9.0.10",
    "web-audio-beat-detector": "^8.2.37",
    "youtubei.js": "^17.2.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@electron/fuses": "^2.1.3",
    "electron": "^43.1.1",
    "electron-builder": "^26.15.7",
    "sass-embedded": "^1.100.0"
  },
  "overrides": {
    "@discordjs/rest": {
      "undici": "6.27.0"
    }
  },
  "optionalDependencies": {
    "@particle/dbus-next": "^0.11.4"
  }
}
