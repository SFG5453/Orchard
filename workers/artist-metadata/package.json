{
  "name": "@orchard/artist-metadata-worker",
  "version": "0.1.0",
  "description": "D1-cached iTunes artist genre resolver for Orchard.",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "wrangler dev --local",
    "deploy": "wrangler deploy",
    "check": "node --check src/index.js && node --test",
    "test": "node --test",
    "d1:create": "wrangler d1 create orchard-artist-metadata",
    "d1:migrate:local": "wrangler d1 migrations apply orchard-artist-metadata --local",
    "d1:migrate:remote": "wrangler d1 migrations apply orchard-artist-metadata --remote"
  },
  "devDependencies": {
    "wrangler": "^4.103.0"
  }
}
